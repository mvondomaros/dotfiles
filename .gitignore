# Ignore everything by default.

*

# Explicit ignore/unignore rules for files in the .config directory.

!.config
!.config/**
.config/jgit
.config/nvim/lazy-lock.json
.config/nvim/lazyvim.json
.config/zsh/.antidote/
.config/zsh/.zplugins.zsh
.config/zsh/.zsh_history
.config/zsh/.zcompdump
.config/zsh/.zcompcache


# Explicit ignore/unignore rules for files in the .opt directory.
!.opt
!.opt/dotfiles
!.opt/dotfiles/**
.config/github-copilot
